// Place your key bindings in this file to overwrite the defaults
[
    {
        "key": "ctrl+shift+s",
        "command": "workbench.action.files.saveAll"
    },
    {
        "key": "ctrl+k s",
        "command": "-workbench.action.files.saveAll"
    },
    {
      "key": "ctrl+-",
      "command": "workbench.action.navigateBack"
    },
    {
      "key": "alt+left",
      "command": "-workbench.action.navigateBack"
    },
    {
      "key": "ctrl+shift+-",
      "command": "workbench.action.navigateForward"
    },
    {
      "key": "alt+right",
      "command": "-workbench.action.navigateForward"
    }
  ]