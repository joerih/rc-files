# Create and export the search path. For the root user the sbin directories
# are included. For non-root users, the current directory is included.
PATH="/bin:/usr/bin:/usr/local/bin:/mingw64/bin:${HOME}/.bin"
if [ "`id -u`" = "0" ]; then
   PATH=/sbin:/usr/sbin:/usr/local/sbin:$PATH
else
   PATH="$PATH:."
fi

# Add MSBuild and Visual Studio Code to the path.
MSBUILDPATH="/C/Program Files (x86)/Microsoft Visual Studio/2017/Professional/MSBuild/15.0/Bin"
VSCODEPATH="$LOCALAPPDATA/Programs/Microsoft VS Code"
PATH="$PATH:$VSCODEPATH:$MSBUILDPATH"

export PATH

# Some other path settings.
export MANPATH="/usr/share/man"

